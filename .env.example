# Supabase - Get from https://supabase.com/dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PromptPay - Sasi's phone number (10 digits, no dashes)
NEXT_PUBLIC_PROMPTPAY_ID=0837845392

# Bank accounts are hardcoded in checkout page (KBank + Krungsri)

# Thailand Post - Real-time tracking
THAILAND_POST_TOKEN=your-token-from-trackapi.thailandpost.co.th

# Email - Resend transactional email (resend.com)
RESEND_API_KEY=re_your_resend_api_key
ADMIN_EMAIL=sasi@obsbooks.com
# FROM_EMAIL is set in lib/resend.ts — update to match your verified Resend domain

# Site URL - used in email links
NEXT_PUBLIC_SITE_URL=https://obsbooks.com

# PayPal - International subscriptions
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENV=sandbox

# Stripe - International order payments (one-off, USD). Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable
# Set after creating webhook endpoint in Stripe dashboard (Phase 4)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cron jobs - Protect with a secret string
CRON_SECRET=your-random-secret-string
